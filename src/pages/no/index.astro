---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import klem from "@assets/klem.jpg";
import before from "@assets/before.webp";
import after from "@assets/after.webp";
---

<Layout>
  <main class="max-w-6xl mx-auto px-4 sm:px-8 py-12 md:py-24">
    <!-- Hero Section -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center mb-32">
      <div
        class="md:col-span-7 order-2 md:order-1 relative z-10 bg-surface-bright/80 backdrop-blur-sm p-8 rounded-2xl shadow-sm"
      >
        <div
          class="inline-block px-4 py-1 mb-6 bg-secondary-container text-on-secondary-container rounded-2xl font-label text-xs uppercase tracking-widest shadow-sm"
        >
          Gudbrandsdalen Valley
        </div>
        <h1
          class="font-sketch text-5xl md:text-7xl text-primary mb-8 leading-tight"
        >
          Where our hands meet the mountain stone.
        </h1>
        <p class="font-headline italic text-2xl text-tertiary mb-10 max-w-lg">
          We're four friends with a dream to build a sanctuary for our
          community.
        </p>
        <div class="flex flex-wrap gap-8 items-center">
          <a
            class="font-headline italic text-xl text-primary border-b border-primary/30 pb-1 hover:border-primary transition-all"
            href="#"
          >
            Our Story
          </a>
          <a
            class="flex items-center gap-2 px-8 py-3 bg-primary text-on-primary rounded-md font-label text-sm hover:opacity-90 transition-opacity shadow-lg"
            href="#"
          >
            Visit Us
            <span class="material-symbols-outlined text-sm">north_east</span>
          </a>
        </div>
      </div>
      <div class="md:col-span-5 order-1 md:order-2 relative">
        <div
          class="relative w-full aspect-4/5 bg-surface-bright/80 rounded-xl overflow-hidden rotate-2 shadow-xl border-10 border-surface-container-lowest"
        >
          <Image
            alt="Four friends standing in a misty Norwegian valley"
            class="w-full h-full object-cover grayscale-20 sepia-10 mix-blend-multiply opacity-90"
            data-alt="Four friends standing in a misty Norwegian valley"
            src={klem}
          />
          <div
            class="absolute bottom-4 right-4 font-sketch text-tertiary text-lg"
          >
            August, 2023
          </div>
        </div>
        <!-- Marginalia Note -->
        <div
          class="absolute -bottom-8 -left-8 md:-left-16 bg-secondary-container text-on-secondary-container p-6 rounded-lg -rotate-3 shadow-lg max-w-50 z-20"
        >
          <p class="font-sketch text-lg leading-snug">
            The valley smells of pine and fresh rain today.
          </p>
        </div>
      </div>
    </section>
    <!-- Scrapbook Grid Section -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8 mb-32">
      <!-- Asymmetric Card 1 -->
      <div class="md:pt-12">
        <div
          class="bg-surface-container-lowest p-6 rounded-md shadow-lg mb-6 -rotate-1"
        >
          <Image
            alt="A simple wooden chapel frame in the mountains"
            class="w-full aspect-square object-cover mb-4 rounded-sm"
            data-alt="A simple wooden chapel frame in the mountains"
            src={before}
          />
          <h3 class="font-headline italic text-xl text-tertiary">The Vision</h3>
          <p class="font-body text-sm text-on-surface-variant mt-2">
            A place of quiet, crafted from the very trees that surround us. No
            pretense, just peace.
          </p>
        </div>
      </div>
      <!-- Central Large Element -->
      <div class="md:col-span-1 relative">
        <div
          class="p-8 text-center bg-surface-bright/80 backdrop-blur-lg rounded-2xl aspect-square flex flex-col justify-center items-center shadow-inner border border-white/20"
        >
          <span
            class="material-symbols-outlined text-4xl text-secondary mb-6"
            data-weight="fill">temple_buddhist</span
          >
          <h2 class="font-headline text-3xl italic text-primary mb-6">
            Built by Hand
          </h2>
          <p class="font-body text-tertiary leading-relaxed mb-8 text-sm">
            Every stone in the foundation was carried by one of us. Every beam
            was measured with a shared laugh. We aren't contractors; we are
            neighbors weaving ourselves into the land.
          </p>
          <div class="w-16 h-px bg-secondary/30 mx-auto mb-8"></div>
          <div class="font-sketch text-2xl text-secondary">
            Mathias, Marie, Ayla og Andreas
          </div>
        </div>
      </div>
      <!-- Asymmetric Card 2 -->
      <div class="md:pt-24">
        <div
          class="bg-surface-container-lowest p-6 rounded-xl shadow-lg rotate-2"
        >
          <Image
            alt="Hand-painted architectural sketch of a small chapel"
            class="w-full aspect-3/4 object-cover mb-4 rounded-sm"
            data-alt="Hand-painted architectural sketch of a small chapel"
            src={after}
          />
          <h3 class="font-headline italic text-xl text-tertiary">
            The Progress
          </h3>
          <p class="font-body text-sm text-on-surface-variant mt-2">
            Currently working on the roof shingles. Cedar scent fills the entire
            meadow.
          </p>
        </div>
      </div>
    </section>
    <!-- Intimate Community Section -->
    <section
      class="bg-surface-container-lowest/80 backdrop-blur-md rounded-3xl p-8 md:p-16 mb-20 relative overflow-hidden shadow-2xl border border-white/30"
    >
      <div class="max-w-2xl mx-auto relative z-10 text-center">
        <h2 class="font-headline text-4xl italic text-primary mb-6">
          Join our fundraiser
        </h2>
        <p class="font-body text-lg text-tertiary mb-10 leading-relaxed">
          We are gathering funds to build out the chapel, we would love your
          support!
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6">
          <a
            target="_blank"
            href="https://www.spleis.no/project/485151?s=c"
            class="bg-primary text-on-primary px-10 py-4 rounded-md font-label text-sm hover:bg-primary/90 shadow-md transition-colors flex items-center justify-center gap-2"
          >
            Donate here
            <span class="material-symbols-outlined text-sm">groups</span>
          </a>
        </div>
      </div>
      <!-- Decorative Sketch -->
      <div class="absolute -right-12 -bottom-12 opacity-5 pointer-events-none">
        <span class="material-symbols-outlined text-[240px]" data-weight="fill"
          >nature_people</span
        >
      </div>
    </section>
  </main>
</Layout>
