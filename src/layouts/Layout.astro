---
import "../styles/global.css";
import { Image } from "astro:assets";
import topIcon from "@assets/glassmaleri.png";
import favicon from "@assets/glassmaleri.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Capella Reginae Norvegiae</title>
    <link rel="icon" href={favicon.src} type="image/x-icon" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Epilogue:ital,wght@0,100..900;1,100..900&family=Caveat:wght@400..700&display=swap"
        rel="stylesheet"
        />
        <!-- Material Symbols -->
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
            />
            <!-- Tailwind CSS -->
  </head>
  <body
      class="valley-bg text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed min-h-screen relative"
      >
      <header
          class="bg-[#fbf9f4]/80 backdrop-blur-md sticky top-0 z-40 border-b border-stone-200/30"
          >
          <nav
              class="flex justify-between items-center w-full px-2 py-4 max-w-5xl mx-auto"
              >
              <a class="flex items-center gap-4" href="/capellareginaenorvegiae">
                <Image height={75} width={75} src={topIcon} alt="Glassmaling" />
                <div class="text-xl font-semibold text-primary font-['Newsreader']">
                  Capella Reginae Norvegiae
                </div>
              </a>
        <div class="hidden md:flex gap-8 items-center">
          <a
              class="text-stone-800 hover:text-primary transition-colors font-['Newsreader'] serif italic tracking-tight"
              href="story">Our Story</a
            >
            <a
                class="text-stone-800 hover:text-primary transition-colors font-['Newsreader'] serif italic tracking-tight"
                href="/capellareginaenorvegiae">The Chapel</a
              >
              <a
                  class="text-stone-800 hover:text-primary transition-colors font-['Newsreader'] serif italic tracking-tight"
                  href="#">Gatherings</a
                >
                <a
                    class="text-stone-800 hover:text-primary transition-colors font-['Newsreader'] serif italic tracking-tight"
                    href="#">Reach Out</a
                  >
        </div>
    <div class="md:hidden">
      <span class="material-symbols-outlined text-primary cursor-pointer"
            >menu</span
          >
    </div>
          </nav>
      </header>
      <slot />
  </body>

  <footer
      class="bg-[#fbf9f4]/90 backdrop-blur-sm w-full mt-20 pb-12 border-t border-stone-300/30 pt-8"
      >
      <div
          class="flex flex-col items-center gap-4 w-full px-4 max-w-4xl mx-auto text-center"
          >
          <div
              class="text-lg font-medium text-stone-900 font-['Newsreader'] italic"
              >
              Capella Reginae Norvegiae
          </div>
            <div class="flex gap-6 mb-4">
              <a
                  class="text-stone-600 hover:text-stone-900 font-['Newsreader'] serif text-sm italic"
                  href="#">Journal</a
                >
                <a
                    class="text-stone-600 hover:text-stone-900 font-['Newsreader'] serif text-sm italic"
                    href="#">Contact</a
                  >
                  <a
                      class="text-stone-600 hover:text-stone-900 font-['Newsreader'] serif text-sm italic"
                      href="#">Privacy</a
                    >
            </div>
        <p class="font-['Newsreader'] serif text-sm italic text-secondary">
        Built with love in the valley.
        </p>
    <div class="mt-4 text-xs font-label text-stone-500">
      © 2026 Mathias and his companions.
    </div>
      </div>
  </footer>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .valley-bg {
    background-image: url("@assets/dalen1.jpg");
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
</style>
